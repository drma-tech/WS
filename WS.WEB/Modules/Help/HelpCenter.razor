@page "/{culture}/help"
@inherits PageCore<HelpCenter>

<HeadComponent Title="Help Center" Description="@($"Get detailed guides, troubleshooting tips, FAQs, and contact support for {AppInfo.Title}. Solve issues and discover features easily.")" Url=@($"/{Culture}/help") Index="false" />
<PageSectionComponent IsPageHeader="true" Title="Help Center" Description="@($"Get detailed guides, troubleshooting tips, FAQs, and contact support for {AppInfo.Title}. Solve issues and discover features easily.")"></PageSectionComponent>

<PageSectionComponent Title="Quick Actions">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="@(async () => { await JsRuntime.Window().InvokeVoidAsync("eval", "Userback && Userback.openForm('general', 'form');"); })">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Feedback"></MudIcon>
                    Feedback
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href="mailto:support@web-standards.com">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Mail"></MudIcon>
                    Contact Support
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/help/faq")>
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Chat"></MudIcon>
                    Browse FAQ
                </MudButton>
            </MudItem>
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Troubleshooting">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="@(async () => { await JsRuntime.Utils().ShowCache(cts.Token); })">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Memory"></MudIcon>
                    Show Cache
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" OnClick="@(async () => { await JsRuntime.Utils().ClearAllStorage(); })">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Clear"></MudIcon>
                    Clear App Data
                </MudButton>
            </MudItem>
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Legal & Privacy">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/legal/terms") Rel="nofollow">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.DocumentScanner"></MudIcon>
                    Terms of Use
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/legal/privacy") Rel="nofollow">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.VerifiedUser"></MudIcon>
                    Privacy Policy
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/legal/credits") Rel="nofollow">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.People"></MudIcon>
                    Credits
                </MudButton>
            </MudItem>
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Get the App">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            @foreach (var store in AppInfo.Stores)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudButton Variant="Variant.Filled" FullWidth="true" Href="@store.Url" Target="_blank" rel="noopener">
                        <MudImage Src="@store.Logo" Class="me-2" Style="width: 20px; vertical-align: top;" Alt="@store.Store" />
                        @store.Store
                    </MudButton>
                </MudItem>
            }
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="Company">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href=@($"/{Culture}/company/about-us")>
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Business"></MudIcon>
                    About us
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href="mailto:contact@drma-tech.com">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Email"></MudIcon>
                    Contact us
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudButton Variant="Variant.Filled" FullWidth="true" Href="https://www.drma-tech.com" Target="_blank" rel="noopener">
                    <MudIcon Class="me-2" Icon="@Icons.Material.Filled.Web"></MudIcon>
                    Website
                </MudButton>
            </MudItem>
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>

<PageSectionComponent Title="More from DRMA Tech">
    <BodyFragment>
        <MudGrid Spacing="@Css.SpaceSmall">
            @foreach (var product in AppInfo.Products)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudButton Variant="Variant.Filled" FullWidth="true" Href="@product.Url" Target="_blank" rel="noopener">
                        <MudImage Src="@product.Logo" Class="me-2" Style="width: 20px; vertical-align: top;" Alt="@product.Title" />
                        @product.Title
                    </MudButton>
                </MudItem>
            }
        </MudGrid>
    </BodyFragment>
</PageSectionComponent>
