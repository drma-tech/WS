@using Microsoft.JSInterop
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime

@if (AppStateStatic.Breakpoint == Breakpoint.Sm) //mobile
{
    //todo: smaller footer
}
else if (AppStateStatic.Breakpoint > Breakpoint.Sm) //other devices
{
    <MudDivider Class="@Css.Build().Small("mb").Raw("mt-20")"></MudDivider>
    <MudGrid Justify="Justify.Center" Style="overflow: auto;" Spacing="@Css.SpaceSmall">
        <MudItem xs="12" sm="12" md="3">
            <MudList T="string" Color="Color.Surface" Dense="true" Gutters="false">
                <MudListSubheader Gutters="false">
                    <MudText Color="Color.Secondary">
                        More from DRMA Tech
                    </MudText>
                </MudListSubheader>
                @foreach (var product in AppInfo.Products.OrderBy(x => rnd.Next()).Take(2))
                {
                    <MudListItem Href="@product.Url" Target="_blank" Class="py-0" Text="@product.Title" SecondaryText="@product.SubTitle">
                        <AvatarContent>
                            <MudImage Src="@product.Logo" Style="width: 30px; vertical-align: top;" />
                        </AvatarContent>
                    </MudListItem>
                }
            </MudList>
        </MudItem>
        <MudItem xs="12" sm="3" md="2">
            <MudList T="string" Dense="true" Gutters="false">
                <MudListSubheader Gutters="false">
                    <MudText Color="Color.Secondary">
                        Company
                    </MudText>
                </MudListSubheader>
                <MudListItem Text="About us" Href="/company/about-us" Class="py-0" Disabled="_blockedActions" />
                <MudListItem Text="Website" Href="https://www.drma-tech.com/" Target="_blank" Class="py-0" />
            </MudList>
        </MudItem>
        <MudItem xs="12" sm="3" md="2">
            <MudList T="string" Dense="true" Gutters="false">
                <MudListSubheader Gutters="false">
                    <MudText Color="Color.Secondary">
                        Get the App
                    </MudText>
                </MudListSubheader>
                @if (CurrentPlatform == Platform.webapp)
                {
                    var filter = new Platform[] { Platform.windows, Platform.play, Platform.ios };
                    @foreach (var store in AppInfo.Stores.Where(p => filter.Contains(p.Platform)))
                    {
                        <MudListItem Href="@store.Url" Target="_blank" Class="py-0">
                            <ChildContent>
                                <MudImage Src="@store.Logo" Class="me-1" Style="width: 20px; vertical-align: top;" />
                                @store.Store
                            </ChildContent>
                        </MudListItem>
                    }
                }
                else if (CurrentPlatform == Platform.windows)
                {
                    var filter = new Platform[] { Platform.play, Platform.ios };
                    @foreach (var store in AppInfo.Stores.Where(p => filter.Contains(p.Platform)))
                    {
                        <MudListItem Href="@store.Url" Target="_blank" Class="py-0">
                            <ChildContent>
                                <MudImage Src="@store.Logo" Class="me-1" Style="width: 20px; vertical-align: top;" />
                                @store.Store
                            </ChildContent>
                        </MudListItem>
                    }
                }
                else
                {
                    var filter = new Platform[] { Platform.windows };
                    @foreach (var store in AppInfo.Stores.Where(p => filter.Contains(p.Platform)))
                    {
                        <MudListItem Href="@store.Url" Target="_blank" Class="py-0">
                            <ChildContent>
                                <MudImage Src="@store.Logo" Class="me-1" Style="width: 20px; vertical-align: top;" />
                                @store.Store
                            </ChildContent>
                        </MudListItem>
                    }
                }
                <MudListItem Href="/help" Class="py-0">
                    <ChildContent>
                        <MudIcon Icon="@IconsFA.Solid.Icon("plus").Font" Class="ma-0 me-1" Style="width: 20px; vertical-align: top;" />
                        More
                    </ChildContent>
                </MudListItem>
            </MudList>
        </MudItem>
        <MudItem xs="12" sm="3" md="2">
            <MudList T="string" Dense="true" Gutters="false">
                <MudListSubheader Gutters="false">
                    <MudText Color="Color.Secondary">
                        Support
                    </MudText>
                </MudListSubheader>
                <MudListItem Text="Help Center" Href="/help" Class="py-0" Disabled="_blockedActions" />
                <MudListItem Text="Contact" Href="mailto:support@web-standards.com" Class="py-0" />
                <MudListItem Text="FAQ" Href="/help/faq" Class="py-0" />
            </MudList>
        </MudItem>
        <MudItem xs="12" sm="3" md="2">
            <MudList T="string" Dense="true" Gutters="false">
                <MudListSubheader Gutters="false">
                    <MudText Color="Color.Secondary">
                        Legal
                    </MudText>
                </MudListSubheader>
                <MudListItem Text="Terms of Use" Href="/legal/terms" Class="py-0" />
                <MudListItem Text="Privacy Policy" Href="/legal/privacy" Class="py-0" />
                <MudListItem Text="Credits" Href="/legal/credits" Class="py-0" />
            </MudList>
        </MudItem>
    </MudGrid>
}

<style>
    .mud-list-item-avatar {
        min-width: 40px;
    }
</style>

@code {
    private static readonly Random rnd = new Random();
    private bool _blockedActions => Navigation.Uri.Contains("register-user") || Navigation.Uri.Contains("ask-consent");
    private Platform? CurrentPlatform;

    protected override void OnInitialized()
    {
        AppStateStatic.BreakpointChanged += breakpoint => StateHasChanged();
        AppStateStatic.BrowserWindowSizeChanged += size => StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            CurrentPlatform = await AppStateStatic.GetPlatform(JsRuntime);
        }
    }
}
